# Generate secrets before first run:
#   openssl rand -base64 32

BETTER_AUTH_SECRET=change-me-to-a-long-random-string
S3_ACCESS_KEY_ID=bunnyfile
S3_SECRET_ACCESS_KEY=change-me
S3_REGION=us-east-1

# SMTP for password-reset emails. If SMTP_HOST is unset, reset links are logged
# to the container's stdout instead of emailed (an admin can relay them).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=BunnyFile <no-reply@example.com>
