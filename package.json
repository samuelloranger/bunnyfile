{
  "name": "bunnyfile",
  "version": "0.0.1",
  "private": true,
  "description": "Lightweight self-hosted file hosting and sharing, built on Bun.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:server": "bun run --filter @bunnyfile/server dev",
    "dev:web": "bun run --filter @bunnyfile/web dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "load-test": "bun scripts/load-test.ts",
    "docker:up": "docker compose up -d && echo '\nWeb:    http://localhost:3900\nServer: http://localhost:3901\n'",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/bun": "1.3.12",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "qrcode.react": "4.2.0"
  }
}
